// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String    @id @default(cuid())
  email                  String    @unique
  passwordHash           String?
  appleId                String?   @unique
  googleId               String?   @unique
  githubId               String?   @unique
  name                   String?
  emailVerified          DateTime?
  verificationToken      String?
  verificationTokenExpiry DateTime?
  resetToken             String?
  resetTokenExpiry       DateTime?
  
  // Neue Felder
  company     String?
  role        String?
  birthday    DateTime? @db.Date
  onboarded   Boolean @default(false)

  // Relations
  checks      ComplianceCheck[]
  tasks       Task[]
  documents   Document[]
  flightTrackers FlightTracker[]
  
  // Sport-Bot Relations
  followedTeams    FollowedTeam[]
  sportSettings    SportBotSettings?
  whatsappSession  WhatsAppSession?
  valueBetSettings ValueBetSettings?

  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}

model ComplianceCheck {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Check Details
  status            CheckStatus @default(IN_PROGRESS)
  riskLevel         RiskLevel?
  completedAt       DateTime?
  
  // Scores
  overallScore      Int? // 0-100
  documentationScore Int?
  technicalScore    Int?
  governanceScore   Int?
  
  // Data
  answers           Json // Fragebogen-Antworten
  recommendations   Json? // AI-generierte Empfehlungen
  
  // Metadata
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  tasks             Task[]
  documents         Document[]
  
  @@index([userId])
  @@index([status])
}

enum CheckStatus {
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum RiskLevel {
  MINIMAL
  LIMITED
  HIGH
  UNACCEPTABLE
}

model Task {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  title       String
  description String?
  status      TaskStatus @default(OPEN)
  priority    Priority @default(MEDIUM)
  dueDate     DateTime?
  
  // Verknüpfung zu Check
  checkId     String?
  check       ComplianceCheck? @relation(fields: [checkId], references: [id], onDelete: SetNull)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([userId])
  @@index([status])
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Document {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  title       String
  type        DocumentType
  content     String? // Markdown oder JSON
  fileUrl     String? // Falls Upload
  version     Int @default(1)
  
  checkId     String?
  check       ComplianceCheck? @relation(fields: [checkId], references: [id], onDelete: SetNull)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([userId])
  @@index([type])
}

enum DocumentType {
  AI_SYSTEM_CARD
  RISK_ASSESSMENT
  DATA_GOVERNANCE
  TECHNICAL_DOCS
  COMPLIANCE_REPORT
  OTHER
}

// ===========================================
// FLUGTRACKER MODELS
// ===========================================

model Airport {
  iataCode    String   @id @db.VarChar(3)
  name        String
  city        String
  country     String
  latitude    Decimal  @db.Decimal(10, 7)
  longitude   Decimal  @db.Decimal(10, 7)
  timezone    String?
  
  @@index([city])
  @@index([country])
  @@map("airports")
}

model FlightTracker {
  id                       String   @id @default(cuid())
  userId                   String
  user                     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name                     String
  departureAirports        String[] // IATA Codes z.B. ["DUS", "FMO"]
  departureRadiusKm        Int      @default(200)
  destinationAirports      String[] // IATA Codes z.B. ["PVG", "SHA"]
  
  dateRangeStart           DateTime @db.Date
  dateRangeEnd             DateTime @db.Date
  tripDurationDays         Int
  flexibility              FlexibilityType @default(EXACT)
  
  travelClass              TravelClass @default(ECONOMY)
  luggageOption            LuggageOption @default(BOTH)
  
  reportFrequency          ReportFrequency @default(WEEKLY)
  priceAlertThresholdPercent Int?
  priceAlertThresholdEuro    Int?
  
  status                   TrackerStatus @default(ACTIVE)
  
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  lastCheckedAt            DateTime?
  
  // Relations
  flightResults            FlightResult[]
  reports                  FlightReport[]
  
  @@index([userId])
  @@index([status])
  @@index([dateRangeEnd])
  @@map("flight_trackers")
}

enum FlexibilityType {
  EXACT
  PLUS_MINUS_1
  PLUS_MINUS_2
}

enum TravelClass {
  ECONOMY
  PREMIUM_ECONOMY
  BUSINESS
  FIRST
}

enum LuggageOption {
  INCLUDED
  HAND_ONLY
  BOTH
}

enum ReportFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

enum TrackerStatus {
  ACTIVE
  PAUSED
  ERROR
  EXPIRED
}

model FlightResult {
  id                  String   @id @default(cuid())
  trackerId           String
  tracker             FlightTracker @relation(fields: [trackerId], references: [id], onDelete: Cascade)
  
  checkedAt           DateTime @default(now())
  departureAirport    String   @db.VarChar(3)
  destinationAirport  String   @db.VarChar(3)
  outboundDate        DateTime @db.Date
  returnDate          DateTime @db.Date
  priceEuro           Decimal  @db.Decimal(10, 2)
  airline             String
  stops               Int      @default(0)
  totalDurationMinutes Int
  luggageIncluded     Boolean  @default(false)
  bookingLink         String?
  source              String   // z.B. "kiwi", "skyscanner"
  
  // Raw data for deduplication
  flightHash          String?  // Hash of flight details for dedup
  
  createdAt           DateTime @default(now())
  
  @@index([trackerId])
  @@index([checkedAt])
  @@index([priceEuro])
  @@index([flightHash])
  @@map("flight_results")
}

model FlightReport {
  id          String   @id @default(cuid())
  trackerId   String
  tracker     FlightTracker @relation(fields: [trackerId], references: [id], onDelete: Cascade)
  
  sentAt      DateTime @default(now())
  reportType  FlightReportType
  contentJson Json
  
  @@index([trackerId])
  @@index([sentAt])
  @@map("flight_reports")
}

enum FlightReportType {
  SCHEDULED
  PRICE_ALERT
}

// ===========================================
// SPORT-BOT MODELS
// ===========================================

model FollowedTeam {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  teamId            Int      // football-data.org team ID
  teamName          String
  teamCrest         String?  // URL to team logo
  teamShortName     String?
  leagueCode        String   // e.g. "BL1", "PL", "PD"
  leagueName        String   // e.g. "Bundesliga", "Premier League"
  leagueEmblem      String?  // URL to league logo
  
  // Notification preferences per team
  notifyGoals       Boolean  @default(true)
  notifyKickoff     Boolean  @default(true)
  notifyHalftime    Boolean  @default(true)
  notifyFulltime    Boolean  @default(true)
  notifyRedCards    Boolean  @default(true)
  notifyPenalties   Boolean  @default(true)
  notifyPreMatch    Boolean  @default(true)   // 15 min before
  
  createdAt         DateTime @default(now())
  
  @@unique([userId, teamId])
  @@index([userId])
  @@index([teamId])
  @@map("followed_teams")
}

model SportMatch {
  id                    String   @id @default(cuid())
  externalId            Int      @unique  // football-data.org match ID
  
  competitionCode       String   // e.g. "BL1"
  competitionName       String
  competitionEmblem     String?
  matchday              Int?
  stage                 String?  // e.g. "REGULAR_SEASON", "QUARTER_FINALS"
  
  homeTeamId            Int
  homeTeamName          String
  homeTeamCrest         String?
  awayTeamId            Int
  awayTeamName          String
  awayTeamCrest         String?
  
  status                MatchStatus @default(SCHEDULED)
  
  // Scores
  homeScoreFullTime     Int?
  awayScoreFullTime     Int?
  homeScoreHalfTime     Int?
  awayScoreHalfTime     Int?
  
  // Timing
  utcDate               DateTime
  minute                Int?       // Current match minute (if live)
  
  // Last update from API
  lastUpdatedAt         DateTime   @default(now())
  
  // Relations
  events                MatchEvent[]
  
  @@index([status])
  @@index([utcDate])
  @@index([homeTeamId])
  @@index([awayTeamId])
  @@map("sport_matches")
}

enum MatchStatus {
  SCHEDULED
  TIMED
  IN_PLAY
  PAUSED       // Halftime
  FINISHED
  SUSPENDED
  POSTPONED
  CANCELLED
  AWARDED
}

model MatchEvent {
  id              String   @id @default(cuid())
  matchId         String
  match           SportMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  
  eventType       SportEventType
  minute          Int
  teamId          Int?
  teamName        String?
  playerName      String?
  detail          String?    // e.g. "Penalty", "Own Goal", "Header"
  
  // Score at the time of this event
  homeScore       Int?
  awayScore       Int?
  
  createdAt       DateTime @default(now())
  
  @@unique([matchId, eventType, minute, playerName])
  @@index([matchId])
  @@map("match_events")
}

enum SportEventType {
  GOAL
  OWN_GOAL
  PENALTY_SCORED
  PENALTY_MISSED
  YELLOW_CARD
  SECOND_YELLOW
  RED_CARD
  SUBSTITUTION
  VAR_DECISION
}

model SentNotification {
  id              String   @id @default(cuid())
  userId          String
  matchExternalId Int
  eventKey        String   // Unique key like "match_123_goal_45_Mueller"
  channel         String   @default("whatsapp") // "whatsapp" or "email"
  messageText     String
  sentAt          DateTime @default(now())
  
  @@unique([userId, eventKey])
  @@index([userId])
  @@index([matchExternalId])
  @@map("sent_notifications")
}

model WhatsAppSession {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  phoneNumber     String?
  sessionName     String   @unique  // WAHA session name
  status          WASessionStatus @default(DISCONNECTED)
  qrCode          String?  @db.Text  // Current QR code for pairing
  lastSeenAt      DateTime?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@map("whatsapp_sessions")
}

enum WASessionStatus {
  DISCONNECTED
  QR_READY
  CONNECTED
  FAILED
}

model SportBotSettings {
  id                    String   @id @default(cuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  preMatchMinutes       Int      @default(15)  // How many minutes before to notify
  notificationsEnabled  Boolean  @default(true)
  quietHoursStart       String?  // e.g. "23:00"
  quietHoursEnd         String?  // e.g. "07:00"
  timezone              String   @default("Europe/Berlin")

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("sportbot_settings")
}

// ===========================================
// VALUE BETTING MODELS
// ===========================================

model TeamStats {
  id                String   @id @default(cuid())
  teamId            Int      // football-data.org team ID
  teamName          String
  competitionCode   String   // e.g. "BL1"
  season            Int      // e.g. 2025

  // Attack/defense strength (relative to league average)
  attackStrength    Float    @default(1.0)
  defenseStrength   Float    @default(1.0)

  // Raw stats
  matchesPlayed     Int      @default(0)
  goalsScored       Int      @default(0)
  goalsConceded     Int      @default(0)
  homeGoalsScored   Int      @default(0)
  homeGoalsConceded Int      @default(0)
  awayGoalsScored   Int      @default(0)
  awayGoalsConceded Int      @default(0)
  homeMatchesPlayed Int      @default(0)
  awayMatchesPlayed Int      @default(0)

  // Form (last 5 matches weighted)
  formAttack        Float    @default(1.0)
  formDefense       Float    @default(1.0)

  updatedAt         DateTime @updatedAt

  @@unique([teamId, competitionCode, season])
  @@index([teamId])
  @@index([competitionCode, season])
  @@map("team_stats")
}

model MatchOdds {
  id                String   @id @default(cuid())
  matchExternalId   Int      // football-data.org match ID

  bookmaker         String   // e.g. "bet365", "pinnacle"
  homeOdds          Float
  drawOdds          Float
  awayOdds          Float

  overUnder25Home   Float?   // Over 2.5 goals odds
  overUnder25Away   Float?   // Under 2.5 goals odds

  fetchedAt         DateTime @default(now())

  @@unique([matchExternalId, bookmaker])
  @@index([matchExternalId])
  @@map("match_odds")
}

model MatchPrediction {
  id                String   @id @default(cuid())
  matchExternalId   Int      @unique // football-data.org match ID

  // Poisson model probabilities
  homeWinProb       Float
  drawProb          Float
  awayWinProb       Float
  overProb          Float    // Over 2.5 goals
  underProb         Float    // Under 2.5 goals

  // Expected goals
  expectedHomeGoals Float
  expectedAwayGoals Float

  // Best value bets found
  bestValueMarket   String?  // "home", "draw", "away", "over", "under"
  bestValueEV       Float?   // Expected value of best bet
  bestValueOdds     Float?   // Odds for best value bet
  bestValueBookmaker String?
  kellyStake        Float?   // Kelly criterion recommended stake %

  // Model metadata
  modelVersion      String   @default("poisson_v1")
  confidence        Float    @default(0.5) // 0-1 model confidence

  // Actual result (filled after match)
  actualResult      String?  // "home", "draw", "away"
  actualHomeGoals   Int?
  actualAwayGoals   Int?
  brierScore        Float?   // Prediction accuracy metric (lower = better)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([matchExternalId])
  @@index([bestValueEV])
  @@map("match_predictions")
}

model ValueBetSettings {
  id                    String   @id @default(cuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  enabled               Boolean  @default(true)
  minEV                 Float    @default(0.05)  // Minimum 5% EV to notify
  maxKellyStake         Float    @default(0.25)  // 25% fractional Kelly
  bankroll              Float    @default(100.0) // Starting bankroll in EUR
  notifyWhatsApp        Boolean  @default(true)

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("value_bet_settings")
}
